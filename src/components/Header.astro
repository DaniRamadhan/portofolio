---
const links = [
  { href: "#about", label: "Tentang" },
  { href: "#venture", label: "Dico" },
  { href: "#skills", label: "Keahlian" },
  { href: "#experience", label: "Portofolio" },
  { href: "#education", label: "Kredensial" },
  { href: "#contact", label: "Kontak" },
];
const name = "Dani Ramadhan";
---

<header class="site-header sticky top-0 z-50 border-b border-line bg-white/70 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3" aria-label="Navigasi utama">
    <!-- Mark ombak + nama -->
    <a href="#top" class="flex items-center gap-2.5 text-sm font-bold text-ink">
      <svg viewBox="0 0 32 32" class="h-7 w-7 text-ink" fill="currentColor" aria-hidden="true">
        <path d="M27,3H5C3.3,3,2,4.3,2,6v15c0,1.7,1.3,3,3,3h22c1.7,0,3-1.3,3-3V6C30,4.3,28.7,3,27,3z M10.7,12.7l-3,3C7.5,15.9,7.3,16,7,16s-0.5-0.1-0.7-0.3c-0.4-0.4-0.4-1,0-1.4L8.6,12L6.3,9.7c-0.4-0.4-0.4-1,0-1.4s1-0.4,1.4,0l3,3C11.1,11.7,11.1,12.3,10.7,12.7z M17,16h-4c-0.6,0-1-0.4-1-1s0.4-1,1-1h4c0.6,0,1,0.4,1,1S17.6,16,17,16z"></path>
        <path d="M23,28L23,28c-1.1,0-2.1-0.7-2.5-1.8c0-0.1-0.1-0.2-0.1-0.2h-8.9c0,0.1,0,0.2-0.1,0.2C11.1,27.3,10.1,28,9,28h0c-0.6,0-1,0.4-1,1s0.4,1,1,1h14c0.6,0,1-0.4,1-1S23.6,28,23,28z"></path>
      </svg>
      <span class="hidden sm:inline">{name}</span>
    </a>

    <!-- Nav desktop -->
    <ul class="hidden items-center gap-8 text-sm font-medium text-slate md:flex">
      {
        links.map((link) => (
          <li>
            <a href={link.href} data-nav={link.href} class="nav-link hover:text-ink">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="#contact"
        class="hidden rounded-lg bg-gradient-to-br from-primary to-primary-deep px-4 py-2 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5 sm:inline-block"
      >
        Hubungi Saya
      </a>

      <!-- Toggle menu mobile -->
      <button
        id="menu-toggle"
        class="grid h-9 w-9 place-items-center rounded-lg border border-line text-ink md:hidden"
        aria-label="Buka menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Panel menu mobile -->
  <div id="mobile-menu" class="hidden border-t border-line bg-white md:hidden">
    <ul class="mx-auto max-w-6xl px-6 py-3 text-sm font-medium text-slate">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="block rounded-lg px-2 py-2.5 hover:bg-sky hover:text-ink" data-mobile-link>
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-1">
        <a href="#contact" data-mobile-link class="block rounded-lg bg-gradient-to-br from-primary to-primary-deep px-3 py-2.5 text-center font-semibold text-white">
          Hubungi Saya
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Header solid saat scroll
  const header = document.querySelector(".site-header");
  const onScroll = () => header?.classList.toggle("scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // Menu mobile toggle
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
  document.querySelectorAll("[data-mobile-link]").forEach((a) =>
    a.addEventListener("click", () => menu?.classList.add("hidden")),
  );

  // Scroll-spy: sorot link nav aktif
  const navLinks = Array.from(document.querySelectorAll("[data-nav]"));
  const sections = navLinks
    .map((l) => document.querySelector(l.getAttribute("data-nav") || ""))
    .filter(Boolean);
  const spy = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const id = "#" + e.target.id;
          navLinks.forEach((l) => l.classList.toggle("active", l.getAttribute("data-nav") === id));
        }
      });
    },
    { rootMargin: "-45% 0px -50% 0px" },
  );
  sections.forEach((s) => spy.observe(s));
</script>
