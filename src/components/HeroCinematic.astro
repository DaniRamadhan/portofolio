---
// =====================================================================
// HeroCinematic.astro — Hero landing sinematik, asimetris & overlapping.
//
// • Tata letak asimetris: headline X-Large sengaja bertumpuk (overlap)
//   dengan area aset visual 3D (slot "visual").
// • Parallax multi-layer (GSAP): gabungan mouse-move + scroll. Tiap layer
//   punya `data-depth` berbeda → ilusi kedalaman 3D.
// • Theme-agnostic: semua warna/asset lewat CSS custom property (var --hx-*)
//   dengan fallback, jadi langsung menyatu dengan tema 3D-mu.
//   Titik kustomisasi ditandai `3D-HOOK`.
//
// Integrasi:
//   <HeroCinematic>
//     <YourThreeCanvas slot="visual" />   {/* aset 3D kamu */}
//   </HeroCinematic>
// Tanpa slot, tampil placeholder abstrak bawaan.
// =====================================================================

interface Cta {
  label: string;
  href: string;
}
interface Props {
  kicker?: string;
  /** Tiap item = satu baris headline (untuk reveal & offset asimetris). */
  titleLines?: string[];
  /** Kata raksasa outline di lapisan paling belakang. */
  ghost?: string;
  lead?: string;
  primary?: Cta;
  secondary?: Cta;
}

const {
  kicker = "Full-Stack Engineer · Founder Dico",
  titleLines = ["Muhammad", "Dani", "Ramadhan"],
  ghost = "ENGINEER",
  lead = "Membangun sistem enterprise berskala besar untuk perbankan & retail — dengan Angular, Spring Boot, dan obsesi pada detail.",
  primary = { label: "Lihat Karya", href: "#experience" },
  secondary = { label: "Hubungi Saya", href: "#contact" },
} = Astro.props;
---

<section class="hero" aria-label="Perkenalan" data-hero>
  <!-- Layer paling belakang: background (glow + grid) -->
  <div class="hero__bg" aria-hidden="true" data-depth="0.12">
    <span class="hero__glow hero__glow--1"></span>
    <span class="hero__glow hero__glow--2"></span>
    <span class="hero__grid"></span>
  </div>

  <!-- Kata raksasa outline (kedalaman) -->
  <span class="hero__ghost" aria-hidden="true" data-depth="0.28" data-scroll="0.35">{ghost}</span>

  <div class="hero__inner">
    <!-- Area aset visual 3D (slot). Sengaja di-overlap oleh headline. -->
    <figure class="hero__visual" data-depth="0.55" data-tilt data-scroll="-0.18">
      <slot name="visual">
        <!-- 3D-HOOK: placeholder abstrak — ganti dengan <YourAsset slot="visual" /> -->
        <div class="hero__orb" aria-hidden="true">
          <span class="hero__orb-core"></span>
          <span class="hero__orb-ring"></span>
          <span class="hero__orb-ring hero__orb-ring--2"></span>
          <span class="hero__shard hero__shard--a" data-depth="0.9"></span>
          <span class="hero__shard hero__shard--b" data-depth="1.1"></span>
          <span class="hero__shard hero__shard--c" data-depth="0.7"></span>
        </div>
      </slot>
    </figure>

    <!-- Konten teks (hierarki tetap scannable: kicker → judul → lead → CTA) -->
    <div class="hero__content">
      <p class="hero__kicker" data-depth="0.85">
        <span class="hero__kicker-dot"></span>{kicker}
      </p>

      <h1 class="hero__title" data-depth="0.4">
        {
          titleLines.map((line, i) => (
            <span class="hero__line" style={`--i:${i}`}>
              <span class="hero__line-inner">{line}</span>
            </span>
          ))
        }
      </h1>

      <p class="hero__lead" data-depth="0.75">{lead}</p>

      <div class="hero__actions" data-depth="0.95">
        <a class="hero__btn hero__btn--primary" href={primary.href}>
          {primary.label}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"></path>
          </svg>
        </a>
        <a class="hero__btn hero__btn--ghost" href={secondary.href}>{secondary.label}</a>
      </div>
    </div>

    <!-- Dekor melayang + petunjuk scroll (layer terdepan) -->
    <span class="hero__stamp" aria-hidden="true" data-depth="1.25">EST. 2020</span>
    <a class="hero__scroll" href={primary.href} aria-label="Gulir ke bawah">
      <span class="hero__scroll-line"></span>
      <span>Scroll</span>
    </a>
  </div>
</section>

<style>
  /* ============================================================
     TOKENS (3D-HOOK) — override var ini agar menyatu dengan tema.
     Semua mewarisi token proyek bila ada, dengan fallback aman.
     ============================================================ */
  .hero {
    --hx-fg: var(--color-ink, #0e1a2b);
    --hx-muted: var(--color-slate, #55637a);
    --hx-accent: var(--color-primary, #0163ea);
    --hx-accent-2: var(--color-accent, #6691f0);
    --hx-line: var(--color-line, #e6eaf1);
    --hx-surface: #ffffff;
    --hx-display: inherit; /* pasang display-face kamu di sini */
    --hx-radius: 1.5rem;
    --hx-max: 78rem;
    --hx-visual-size: clamp(18rem, 42vw, 34rem);

    position: relative;
    overflow: hidden;
    isolation: isolate;
    color: var(--hx-fg);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: var(--hx-max);
    margin-inline: auto;
    min-height: min(100svh, 56rem);
    padding: clamp(5rem, 12vh, 9rem) clamp(1.25rem, 5vw, 3rem) clamp(3rem, 8vh, 6rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ============================ BACKGROUND ============================ */
  .hero__bg {
    position: absolute;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
  }
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.5;
  }
  .hero__glow--1 {
    width: 42vw;
    height: 42vw;
    top: -8%;
    left: -6%;
    background: var(--hx-accent-2);
    opacity: 0.35;
  }
  .hero__glow--2 {
    width: 46vw;
    height: 46vw;
    right: -10%;
    bottom: -14%;
    background: var(--hx-accent);
    opacity: 0.28;
  }
  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--hx-accent) 8%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--hx-accent) 8%, transparent) 1px, transparent 1px);
    background-size: 3.2rem 3.2rem;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 60% 40%, #000 30%, transparent 75%);
    mask-image: radial-gradient(ellipse 70% 60% at 60% 40%, #000 30%, transparent 75%);
  }

  /* ============================ GHOST WORD ============================ */
  .hero__ghost {
    position: absolute;
    z-index: 1;
    top: 50%;
    right: -2%;
    transform: translateY(-50%);
    font-family: var(--hx-display);
    font-size: clamp(6rem, 24vw, 10rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--hx-accent) 22%, transparent);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  /* ============================ VISUAL (ASET 3D) ============================ */
  /* 3D-HOOK: kontainer aset. `perspective` menyiapkan tilt 3D. */
  .hero__visual {
    position: absolute;
    z-index: 2; /* di belakang teks utama, di depan ghost */
    top: 50%;
    right: clamp(0rem, 4vw, 4rem);
    width: var(--hx-visual-size);
    height: var(--hx-visual-size);
    margin: 0;
    transform: translateY(-50%);
    perspective: 1000px;
    will-change: transform;
  }
  .hero__visual > :global(*) {
    width: 100%;
    height: 100%;
  }

  /* Placeholder abstrak (dihapus otomatis bila slot diisi) */
  .hero__orb {
    position: relative;
    display: grid;
    place-items: center;
    border-radius: 50%;
    transform-style: preserve-3d;
  }
  .hero__orb-core {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background:
      radial-gradient(circle at 32% 28%, color-mix(in srgb, var(--hx-accent-2) 90%, #fff) 0%, var(--hx-accent) 45%, color-mix(in srgb, var(--hx-accent) 60%, #000) 100%);
    box-shadow:
      inset 0 10px 40px rgba(255, 255, 255, 0.35),
      0 30px 80px -30px color-mix(in srgb, var(--hx-accent) 60%, transparent);
  }
  .hero__orb-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid color-mix(in srgb, var(--hx-accent) 35%, transparent);
  }
  .hero__orb-ring--2 {
    inset: 9%;
    border-color: color-mix(in srgb, var(--hx-accent-2) 40%, transparent);
  }
  .hero__shard {
    position: absolute;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, var(--hx-accent), var(--hx-accent-2));
    box-shadow: 0 20px 40px -18px color-mix(in srgb, var(--hx-accent) 70%, transparent);
  }
  .hero__shard--a {
    width: 3.5rem;
    height: 3.5rem;
    top: -4%;
    right: 6%;
    transform: rotate(18deg);
  }
  .hero__shard--b {
    width: 2.2rem;
    height: 2.2rem;
    bottom: 4%;
    left: -4%;
    border-radius: 50%;
    background: var(--hx-surface);
    border: 1px solid var(--hx-line);
  }
  .hero__shard--c {
    width: 2.6rem;
    height: 2.6rem;
    bottom: 16%;
    right: -6%;
    transform: rotate(-12deg);
    opacity: 0.85;
  }

  /* ============================ TEKS ============================ */
  .hero__content {
    position: relative;
    z-index: 3; /* headline overlap DI DEPAN visual */
    max-width: min(100%, 60rem); /* cukup lebar agar judul X-large tak terpotong */
    pointer-events: none; /* biar area kosong tak menghalangi hover visual */
  }
  .hero__content :where(a, button) {
    pointer-events: auto;
  }

  .hero__kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hx-accent);
  }
  .hero__kicker-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--hx-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--hx-accent) 18%, transparent);
  }

  .hero__title {
    margin: 1.1rem 0 0;
    font-family: var(--hx-display);
    font-weight: 800;
    font-size: clamp(2.75rem, 11vw, 9rem);
    line-height: 0.9;
    letter-spacing: -0.035em;
    /* halo tipis agar tetap terbaca saat menimpa area visual */
    filter: drop-shadow(0 6px 22px color-mix(in srgb, var(--hx-surface) 55%, transparent));
  }
  .hero__line {
    display: block;
    overflow: hidden; /* untuk reveal clip */
    /* offset asimetris progresif tiap baris */
    margin-left: calc(var(--i, 0) * clamp(0.5rem, 4vw, 3.5rem));
  }
  .hero__line-inner {
    display: block;
  }
  /* baris terakhir diberi aksen gradient */
  .hero__line:last-child .hero__line-inner {
    background: linear-gradient(100deg, var(--hx-accent), var(--hx-accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__lead {
    margin-top: 1.6rem;
    max-width: 34rem;
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.6;
    color: var(--hx-muted);
  }

  .hero__actions {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  /* 3D-HOOK: tombol — beri efek 3D/gloss sesuai tema */
  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.4rem;
    border-radius: 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }
  .hero__btn svg {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.2s ease;
  }
  .hero__btn--primary {
    color: #fff;
    background: linear-gradient(120deg, var(--hx-accent), color-mix(in srgb, var(--hx-accent) 70%, #000));
    box-shadow: 0 18px 40px -18px color-mix(in srgb, var(--hx-accent) 80%, transparent);
  }
  .hero__btn--primary:hover {
    transform: translateY(-2px);
  }
  .hero__btn--primary:hover svg {
    transform: translateX(3px);
  }
  .hero__btn--ghost {
    color: var(--hx-fg);
    background: color-mix(in srgb, var(--hx-surface) 70%, transparent);
    border: 1px solid var(--hx-line);
    backdrop-filter: blur(6px);
  }
  .hero__btn--ghost:hover {
    border-color: color-mix(in srgb, var(--hx-accent) 45%, transparent);
    color: var(--hx-accent);
  }

  /* ============================ DEKOR ============================ */
  .hero__stamp {
    position: absolute;
    z-index: 4;
    top: clamp(4rem, 12vh, 7rem);
    right: clamp(1rem, 4vw, 3rem);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    color: var(--hx-muted);
    writing-mode: vertical-rl;
    opacity: 0.7;
  }
  .hero__scroll {
    position: absolute;
    z-index: 4;
    left: clamp(1.25rem, 5vw, 3rem);
    bottom: clamp(1.5rem, 5vh, 3rem);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hx-muted);
    text-decoration: none;
  }
  .hero__scroll-line {
    width: 2.5rem;
    height: 1px;
    background: currentColor;
    transform-origin: left;
    animation: hero-scroll 1.8s ease-in-out infinite;
  }
  @keyframes hero-scroll {
    0%, 100% { transform: scaleX(0.4); opacity: 0.5; }
    50% { transform: scaleX(1); opacity: 1; }
  }

  /* ============================ RESPONSIF ============================ */
  /* Di layar kecil: visual pindah ke atas, tak lagi absolute overlap. */
  @media (max-width: 860px) {
    .hero__inner {
      justify-content: flex-start;
    }
    .hero__visual {
      position: relative;
      top: auto;
      right: auto;
      transform: none;
      margin: 0 auto 2rem;
      --hx-visual-size: clamp(14rem, 60vw, 20rem);
      order: -1;
    }
    .hero__content {
      max-width: none;
    }
    .hero__ghost {
      font-size: 40vw;
      opacity: 0.6;
    }
    .hero__stamp {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__scroll-line {
      animation: none;
    }
  }
</style>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const hero = document.querySelector<HTMLElement>("[data-hero]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!hero) throw new Error("hero missing");

  try {
    // ---------- 1) Entrance timeline ----------
    if (!reduce) {
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.from(".hero__kicker", { y: 24, autoAlpha: 0, duration: 0.6 })
        .from(
          ".hero__line-inner",
          { yPercent: 115, autoAlpha: 0, duration: 0.95, stagger: 0.12 },
          "-=0.25",
        )
        .from(".hero__lead", { y: 24, autoAlpha: 0, duration: 0.6 }, "-=0.5")
        .from(".hero__actions > *", { y: 18, autoAlpha: 0, duration: 0.5, stagger: 0.1 }, "-=0.35")
        .from(".hero__visual", { scale: 0.88, autoAlpha: 0, duration: 1.1 }, "-=1.1")
        .from(".hero__ghost", { autoAlpha: 0, duration: 1.2 }, "<")
        .from([".hero__stamp", ".hero__scroll"], { autoAlpha: 0, duration: 0.6 }, "-=0.6");
    }

    // ---------- 2) Parallax mouse-move (multi-layer) ----------
    const layers = gsap.utils.toArray<HTMLElement>("[data-depth]");
    const move = layers.map((el) => ({
      depth: parseFloat(el.dataset.depth || "0.2"),
      xTo: gsap.quickTo(el, "x", { duration: 0.7, ease: "power3" }),
      yTo: gsap.quickTo(el, "y", { duration: 0.7, ease: "power3" }),
    }));

    // tilt 3D untuk area visual
    const visual = hero.querySelector<HTMLElement>("[data-tilt]");
    const rotX = visual ? gsap.quickTo(visual, "rotationX", { duration: 0.7, ease: "power3" }) : null;
    const rotY = visual ? gsap.quickTo(visual, "rotationY", { duration: 0.7, ease: "power3" }) : null;

    if (!reduce && window.matchMedia("(pointer: fine)").matches) {
      hero.addEventListener("pointermove", (e) => {
        const r = hero.getBoundingClientRect();
        const nx = (e.clientX - r.left) / r.width - 0.5; // -0.5..0.5
        const ny = (e.clientY - r.top) / r.height - 0.5;
        move.forEach((m) => {
          m.xTo(-nx * m.depth * 52);
          m.yTo(-ny * m.depth * 52);
        });
        rotX?.(ny * 8);
        rotY?.(-nx * 9);
      });
      hero.addEventListener("pointerleave", () => {
        move.forEach((m) => {
          m.xTo(0);
          m.yTo(0);
        });
        rotX?.(0);
        rotY?.(0);
      });
    }

    // ---------- 3) Parallax scroll (kecepatan berbeda per layer) ----------
    if (!reduce) {
      gsap.utils.toArray<HTMLElement>("[data-scroll]").forEach((el) => {
        const rate = parseFloat(el.dataset.scroll || "0");
        gsap.to(el, {
          yPercent: rate * 100,
          ease: "none",
          scrollTrigger: { trigger: hero, start: "top top", end: "bottom top", scrub: true },
        });
      });
      // background bergerak paling lambat
      gsap.to(".hero__bg", {
        yPercent: 12,
        ease: "none",
        scrollTrigger: { trigger: hero, start: "top top", end: "bottom top", scrub: true },
      });
    }
  } catch (err) {
    console.error("Hero motion gagal:", err);
    gsap.set([".hero__content", ".hero__visual", ".hero__ghost", ".hero__stamp", ".hero__scroll"], {
      autoAlpha: 1,
      clearProps: "transform",
    });
  }
</script>
